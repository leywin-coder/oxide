# Oxide Agentic IDE .gitignore
# Ignores files and directories specific to the project

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# Build and output directories
/dist/
/build/
/out/
/target/
/oxide-engine/target/

# Dependency directories
/node_modules/
/vendor/
/venv/
/env/
/__pycache__/

# Environment files
.env
.env.local
.env.development
.env.production

# OS-specific files
.DS_Store
Thumbs.db
ehthumbs.db
Icon
._*
.Spotlight-V100
.Trashes

# Log and debug files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
/coverage/
/test-results/

# Language-specific files
# Rust
Cargo.lock
rust-toolchain
*.rlib
*.rmeta

# Node.js
package-lock.json
yarn.lock
pnpm-lock.yaml

# Python
*.py[cod]
__pycache__/
*.egg-info/
.pytest_cache/

# Go
go.mod
go.sum
bin/
*.test

# Docker
Dockerfile
docker-compose.yml
.dockerignore

# Configuration files
/config/
/configs/
/settings/
/*.config
/oxide-engine/config.toml

# Temporary files
*.tmp
*.temp
*.bak
